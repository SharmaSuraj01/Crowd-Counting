<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Crowd Analysis System</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .gradient-bg { background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #334155 100%); }
        .glow { box-shadow: 0 0 40px rgba(99, 102, 241, 0.3); }
        .alert-glow { box-shadow: 0 0 40px rgba(239, 68, 68, 0.5); }
        .border-3 { border-width: 3px; }
        .tab-active { background: linear-gradient(to right, #6366f1, #9333ea); color: white; }
    </style>
</head>
<body class="gradient-bg min-h-screen">
    <div class="container mx-auto px-4 py-8 max-w-7xl">

        <header class="text-center mb-10">
            <div class="flex justify-end mb-2">
                <button onclick="toggleHistory()" class="bg-slate-700/80 hover:bg-slate-600 text-slate-300 hover:text-white text-sm font-semibold px-4 py-2 rounded-xl border border-slate-600/50 transition-all">📊 History & Stats</button>
            </div>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-3">
                <div class="w-14 h-14 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-2xl flex items-center justify-center glow flex-shrink-0">
                    <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                </div>
                <h1 class="text-3xl sm:text-5xl font-bold bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent">AI Crowd Analysis System</h1>
            </div>
            <p class="text-slate-400 text-base sm:text-lg font-medium">Powered by YOLOv8 Neural Network</p>
        </header>

        <!-- Mode Tabs -->
        <div class="flex gap-3 mb-6 bg-slate-800/50 p-2 rounded-2xl border border-slate-700/50 w-fit mx-auto">
            <button id="tabImage" onclick="switchMode('image')" class="tab-active px-6 py-2 rounded-xl font-semibold text-sm transition-all duration-300">🖼 Image</button>
            <button id="tabVideo" onclick="switchMode('video')" class="px-6 py-2 rounded-xl font-semibold text-sm text-slate-400 hover:text-white transition-all duration-300">🎥 Video</button>
            <button id="tabWebcam" onclick="switchMode('webcam')" class="px-6 py-2 rounded-xl font-semibold text-sm text-slate-400 hover:text-white transition-all duration-300">📷 Live Webcam</button>
        </div>

        <!-- Upload Card -->
        <div id="uploadCard" class="bg-slate-800/50 backdrop-blur-xl rounded-3xl p-4 sm:p-8 mb-8 border border-slate-700/50 shadow-2xl">
            <div id="uploadArea" class="border-3 border-dashed border-slate-600 rounded-2xl p-8 sm:p-16 text-center transition-all duration-300 hover:border-indigo-500 hover:bg-slate-700/30 cursor-pointer">
                <svg class="w-16 h-16 sm:w-20 sm:h-20 mx-auto mb-4 sm:mb-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
                </svg>
                <h3 class="text-xl sm:text-2xl font-bold text-white mb-2" id="uploadTitle">Upload Image</h3>
                <p class="text-slate-400 mb-4 sm:mb-6 text-sm sm:text-base" id="fileName">Drag & drop or click to browse</p>
                <input type="file" id="imageInput" accept="image/*" class="hidden">
                <input type="file" id="videoInput" accept="video/*" class="hidden">
                <button onclick="triggerUpload()" class="bg-gradient-to-r from-indigo-500 to-purple-600 text-white px-6 sm:px-8 py-2 sm:py-3 rounded-xl font-semibold hover:from-indigo-600 hover:to-purple-700 transition-all duration-300 shadow-lg hover:scale-105 text-sm sm:text-base">
                    Choose File
                </button>
            </div>

            <!-- Alert Threshold -->
            <div class="mt-4 flex items-center gap-4 bg-slate-900/40 rounded-xl px-4 py-3">
                <span class="text-slate-400 text-sm font-medium whitespace-nowrap">⚠ Alert Threshold:</span>
                <input type="range" id="thresholdSlider" min="1" max="100" value="10" class="flex-1 accent-indigo-500" oninput="document.getElementById('thresholdVal').textContent = this.value">
                <span id="thresholdVal" class="text-indigo-400 font-bold text-sm w-8 text-center">10</span>
                <span class="text-slate-400 text-sm">people</span>
            </div>

            <button id="analyzeBtn" onclick="analyze()" disabled class="w-full mt-4 sm:mt-6 bg-gradient-to-r from-emerald-500 to-teal-600 text-white px-6 sm:px-8 py-3 sm:py-4 rounded-xl font-bold text-base sm:text-lg hover:from-emerald-600 hover:to-teal-700 transition-all duration-300 shadow-lg disabled:from-slate-600 disabled:to-slate-700 disabled:cursor-not-allowed flex items-center justify-center gap-3 hover:scale-[1.02]">
                <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                Analyze
            </button>
        </div>

        <!-- Webcam Card -->
        <div id="webcamCard" class="hidden bg-slate-800/50 backdrop-blur-xl rounded-3xl p-4 sm:p-8 mb-8 border border-slate-700/50 shadow-2xl">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div>
                    <h3 class="text-white font-semibold mb-3">📷 Live Camera Feed</h3>
                    <video id="webcamVideo" autoplay muted playsinline class="w-full rounded-2xl shadow-xl bg-black"></video>
                    <div class="flex gap-3 mt-4">
                        <button id="startWebcamBtn" onclick="startWebcam()" class="flex-1 bg-gradient-to-r from-indigo-500 to-purple-600 text-white py-2 rounded-xl font-semibold text-sm hover:scale-105 transition-all">▶ Start Camera</button>
                        <button id="stopWebcamBtn" onclick="stopWebcam()" disabled class="flex-1 bg-gradient-to-r from-red-500 to-rose-600 text-white py-2 rounded-xl font-semibold text-sm disabled:from-slate-600 disabled:to-slate-700 disabled:cursor-not-allowed hover:scale-105 transition-all">⏹ Stop</button>
                    </div>
                    <div class="mt-3 flex items-center gap-3 bg-slate-900/40 rounded-xl px-4 py-2">
                        <span class="text-slate-400 text-xs">Analysis Speed:</span>
                        <select id="webcamFps" class="bg-slate-700 text-white text-xs rounded-lg px-2 py-1 border border-slate-600">
                            <option value="2000">Slow (every 2s)</option>
                            <option value="1000" selected>Normal (every 1s)</option>
                            <option value="500">Fast (every 0.5s)</option>
                        </select>
                        <div id="webcamStatus" class="ml-auto flex items-center gap-2">
                            <div id="webcamDot" class="w-2 h-2 rounded-full bg-slate-500"></div>
                            <span id="webcamStatusText" class="text-slate-400 text-xs">Idle</span>
                        </div>
                    </div>
                </div>
                <div>
                    <h3 class="text-white font-semibold mb-3">🎯 Live Detection</h3>
                    <img id="webcamOutput" class="w-full rounded-2xl shadow-xl bg-slate-900/50 min-h-[200px]" alt="Detection output">
                    <div class="grid grid-cols-2 gap-3 mt-4">
                        <div class="bg-slate-900/40 rounded-xl p-3 text-center">
                            <p class="text-slate-400 text-xs">👤 People</p>
                            <p id="wcPersonCount" class="text-3xl font-bold text-indigo-400">0</p>
                            <div class="flex justify-center gap-2 mt-1">
                                <span class="text-xs text-blue-400">👨 <span id="wcMale">0</span></span>
                                <span class="text-xs text-pink-400">👩 <span id="wcFemale">0</span></span>
                            </div>
                        </div>
                        <div class="bg-slate-900/40 rounded-xl p-3 text-center">
                            <p class="text-slate-400 text-xs">Density</p>
                            <span id="wcDensity" class="text-sm font-bold px-2 py-1 rounded-full bg-slate-600 text-slate-200">-</span>
                        </div>
                        <div class="bg-slate-900/40 rounded-xl p-3 text-center">
                            <p class="text-slate-400 text-xs">🎯 Confidence</p>
                            <p id="wcConfidence" class="text-2xl font-bold text-emerald-400">0%</p>
                        </div>
                        <div class="bg-slate-900/40 rounded-xl p-3 text-center">
                            <p class="text-slate-400 text-xs">⚡ Speed</p>
                            <p id="wcSpeed" class="text-2xl font-bold text-sky-400">0ms</p>
                        </div>
                    </div>
                    <div id="wcObjects" class="mt-3 flex flex-wrap gap-2"></div>
                </div>
            </div>
        </div>

        <!-- Loading -->
        <div id="loading" class="hidden bg-slate-800/50 backdrop-blur-xl rounded-3xl p-8 sm:p-16 text-center border border-slate-700/50 shadow-2xl">
            <div class="w-16 h-16 sm:w-20 sm:h-20 border-4 border-slate-600 border-t-indigo-500 rounded-full animate-spin mx-auto mb-4 sm:mb-6"></div>
            <p class="text-lg sm:text-xl font-semibold text-indigo-400" id="loadingText">Analyzing...</p>
        </div>

        <!-- Alert Banner -->
        <div id="alertBanner" class="hidden mb-6 bg-red-500/20 border border-red-500/50 rounded-2xl p-4 flex items-center gap-4 alert-glow">
            <span class="text-3xl">🚨</span>
            <div>
                <p class="text-red-400 font-bold text-lg">CROWD ALERT!</p>
                <p id="alertMsg" class="text-red-300 text-sm"></p>
            </div>
        </div>

        <!-- Image Results -->
        <div id="imageResults" class="hidden space-y-6">
            <!-- Stats -->
            <div class="bg-slate-800/50 backdrop-blur-xl rounded-3xl p-4 sm:p-8 border border-slate-700/50 shadow-2xl glow">
                <div class="grid grid-cols-2 lg:grid-cols-5 gap-4">
                    <div class="flex flex-col items-center justify-center bg-slate-900/40 rounded-2xl p-4 gap-2">
                        <p class="text-slate-400 text-xs font-medium">👤 People Detected</p>
                        <p id="personCount" class="text-5xl font-bold bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent">0</p>
                        <div class="flex gap-3">
                            <span class="text-xs font-bold text-blue-400">👨 <span id="maleCount">0</span></span>
                            <span class="text-xs font-bold text-pink-400">👩 <span id="femaleCount">0</span></span>
                        </div>
                    </div>
                    <div class="flex flex-col items-center justify-center bg-slate-900/40 rounded-2xl p-4 gap-2">
                        <p class="text-slate-400 text-xs font-medium">🚗 Cars Detected</p>
                        <p id="carCount" class="text-5xl font-bold text-orange-400">0</p>
                    </div>
                    <div class="flex flex-col items-center justify-center bg-slate-900/40 rounded-2xl p-4 gap-2">
                        <p class="text-slate-400 text-xs font-medium">Avg Confidence</p>
                        <p id="avgConfidence" class="text-3xl font-bold text-emerald-400">0%</p>
                    </div>
                    <div class="flex flex-col items-center justify-center bg-slate-900/40 rounded-2xl p-4 gap-2">
                        <p class="text-slate-400 text-xs font-medium">Density Level</p>
                        <span id="densityBadge" class="text-sm font-bold px-3 py-1 rounded-full">-</span>
                    </div>
                    <div class="flex flex-col items-center justify-center bg-slate-900/40 rounded-2xl p-4 gap-2">
                        <p class="text-slate-400 text-xs font-medium">Processing Time</p>
                        <p id="processingTime" class="text-3xl font-bold text-sky-400">0ms</p>
                    </div>
                </div>
            </div>

            <!-- Image Tabs -->
            <div class="bg-slate-800/50 backdrop-blur-xl rounded-3xl overflow-hidden border border-slate-700/50 shadow-2xl">
                <div class="bg-slate-700/50 px-4 sm:px-6 py-3 border-b border-slate-600/50 flex gap-2 flex-wrap">
                    <button onclick="showImgTab('original')" id="btnOriginal" class="tab-active px-4 py-1.5 rounded-lg text-sm font-semibold transition-all">Original</button>
                    <button onclick="showImgTab('detection')" id="btnDetection" class="px-4 py-1.5 rounded-lg text-sm font-semibold text-slate-400 hover:text-white transition-all">Detection</button>
                    <button onclick="showImgTab('heatmap')" id="btnHeatmap" class="px-4 py-1.5 rounded-lg text-sm font-semibold text-slate-400 hover:text-white transition-all">Heatmap</button>
                    <button onclick="downloadResult()" class="ml-auto bg-slate-600 hover:bg-slate-500 text-white text-xs font-bold px-3 py-1.5 rounded-lg transition-colors">⬇ Download</button>
                </div>
                <div class="p-4 sm:p-6 bg-slate-900/30">
                    <img id="originalImage" class="w-full rounded-2xl shadow-xl" alt="Original">
                    <img id="outputImage" class="w-full rounded-2xl shadow-xl hidden" alt="Detection">
                    <img id="heatmapImage" class="w-full rounded-2xl shadow-xl hidden" alt="Heatmap">
                </div>
            </div>
        </div>

        <!-- History & Stats Panel -->
        <div id="historyPanel" class="hidden bg-slate-800/50 backdrop-blur-xl rounded-3xl p-4 sm:p-8 mb-8 border border-slate-700/50 shadow-2xl">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-white font-bold text-xl">📊 Analysis History & Stats</h2>
                <div class="flex gap-2">
                    <a href="/export/csv" class="bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-bold px-3 py-2 rounded-lg transition-colors">⬇ Export CSV</a>
                    <button onclick="clearHistory()" class="bg-red-600/80 hover:bg-red-700 text-white text-xs font-bold px-3 py-2 rounded-lg transition-colors">🗑 Clear</button>
                    <button onclick="toggleHistory()" class="bg-slate-600 hover:bg-slate-500 text-white text-xs font-bold px-3 py-2 rounded-lg transition-colors">✕ Close</button>
                </div>
            </div>
            <!-- Stats Cards -->
            <div id="statsCards" class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6"></div>
            <!-- History Table -->
            <div class="overflow-x-auto rounded-2xl">
                <table class="w-full text-sm text-left">
                    <thead class="bg-slate-700/60 text-slate-300">
                        <tr>
                            <th class="px-4 py-3">Type</th>
                            <th class="px-4 py-3">File</th>
                            <th class="px-4 py-3">People</th>
                            <th class="px-4 py-3">Cars</th>
                            <th class="px-4 py-3">Density</th>
                            <th class="px-4 py-3">Confidence</th>
                            <th class="px-4 py-3">Alert</th>
                            <th class="px-4 py-3">Time</th>
                        </tr>
                    </thead>
                    <tbody id="historyTableBody" class="divide-y divide-slate-700/50"></tbody>
                </table>
            </div>
        </div>

        <!-- Video Results -->
        <div id="videoResults" class="hidden space-y-6">
            <div class="bg-slate-800/50 backdrop-blur-xl rounded-3xl p-4 sm:p-8 border border-slate-700/50 shadow-2xl glow">
                <div class="grid grid-cols-2 lg:grid-cols-5 gap-4">
                    <div class="flex flex-col items-center justify-center bg-slate-900/40 rounded-2xl p-4 gap-2">
                        <p class="text-slate-400 text-xs font-medium">Peak Total</p>
                        <p id="maxCount" class="text-5xl font-bold bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent">0</p>
                    </div>
                    <div class="flex flex-col items-center justify-center bg-slate-900/40 rounded-2xl p-4 gap-2">
                        <p class="text-slate-400 text-xs font-medium">👤 Peak People</p>
                        <p id="maxPersons" class="text-3xl font-bold text-indigo-400">0</p>
                    </div>
                    <div class="flex flex-col items-center justify-center bg-slate-900/40 rounded-2xl p-4 gap-2">
                        <p class="text-slate-400 text-xs font-medium">🚗 Peak Cars</p>
                        <p id="maxCars" class="text-3xl font-bold text-orange-400">0</p>
                    </div>
                    <div class="flex flex-col items-center justify-center bg-slate-900/40 rounded-2xl p-4 gap-2">
                        <p class="text-slate-400 text-xs font-medium">Avg Count</p>
                        <p id="avgCount" class="text-3xl font-bold text-emerald-400">0</p>
                    </div>
                    <div class="flex flex-col items-center justify-center bg-slate-900/40 rounded-2xl p-4 gap-2">
                        <p class="text-slate-400 text-xs font-medium">Density Level</p>
                        <span id="videoDensityBadge" class="text-sm font-bold px-3 py-1 rounded-full">-</span>
                    </div>
                </div>
            </div>

            <!-- Crowd Over Time Chart -->
            <div class="bg-slate-800/50 backdrop-blur-xl rounded-3xl p-4 sm:p-8 border border-slate-700/50 shadow-2xl">
                <h3 class="text-white font-semibold mb-2">📈 Crowd Count Over Time</h3>
                <p class="text-slate-400 text-xs mb-4">💡 Click on any point to see detection for that frame</p>
                <canvas id="crowdChart" height="100"></canvas>
            </div>

            <!-- Frame Modal -->
            <div id="frameModal" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
                <div class="bg-slate-800 rounded-3xl border border-slate-600 shadow-2xl max-w-3xl w-full max-h-[90vh] overflow-y-auto">
                    <div class="flex items-center justify-between p-4 border-b border-slate-700">
                        <h3 id="modalTitle" class="text-white font-bold text-lg">Frame Detection</h3>
                        <button onclick="closeModal()" class="text-slate-400 hover:text-white text-2xl leading-none">&times;</button>
                    </div>
                    <div class="p-4">
                        <img id="modalImage" class="w-full rounded-2xl shadow-xl mb-4" alt="Frame Detection">
                        <div id="modalStats" class="grid grid-cols-2 sm:grid-cols-4 gap-3"></div>
                    </div>
                </div>
            </div>

            <!-- Video Preview Tabs -->
            <div class="bg-slate-800/50 backdrop-blur-xl rounded-3xl overflow-hidden border border-slate-700/50 shadow-2xl">
                <div class="bg-slate-700/50 px-4 sm:px-6 py-3 border-b border-slate-600/50 flex gap-2">
                    <button onclick="showVidTab('preview')" id="btnVidPreview" class="tab-active px-4 py-1.5 rounded-lg text-sm font-semibold transition-all">Last Frame</button>
                    <button onclick="showVidTab('vidheatmap')" id="btnVidHeatmap" class="px-4 py-1.5 rounded-lg text-sm font-semibold text-slate-400 hover:text-white transition-all">Heatmap</button>
                </div>
                <div class="p-4 sm:p-6 bg-slate-900/30">
                    <img id="videoPreview" class="w-full rounded-2xl shadow-xl" alt="Preview">
                    <img id="videoHeatmap" class="w-full rounded-2xl shadow-xl hidden" alt="Heatmap">
                </div>
            </div>
        </div>

    </div>

    <script>
        let currentMode = 'image';
        let historyVisible = false;
        let crowdChartInstance = null;
        let webcamStream = null;
        let webcamInterval = null;
        let webcamBusy = false;
        let webcamCanvas = document.createElement('canvas');

        const densityColors = {
            'Empty':     'bg-slate-600 text-slate-200',
            'Low':       'bg-emerald-500/20 text-emerald-400',
            'Medium':    'bg-yellow-500/20 text-yellow-400',
            'High':      'bg-orange-500/20 text-orange-400',
            'Very High': 'bg-red-500/20 text-red-400'
        };

        function switchMode(mode) {
            currentMode = mode;
            ['image','video','webcam'].forEach(m => {
                const btn = document.getElementById('tab' + m.charAt(0).toUpperCase() + m.slice(1));
                btn.className = m === mode
                    ? 'tab-active px-6 py-2 rounded-xl font-semibold text-sm transition-all duration-300'
                    : 'px-6 py-2 rounded-xl font-semibold text-sm text-slate-400 hover:text-white transition-all duration-300';
            });
            document.getElementById('uploadCard').classList.toggle('hidden', mode === 'webcam');
            document.getElementById('webcamCard').classList.toggle('hidden', mode !== 'webcam');
            if (mode !== 'webcam') stopWebcam();
            if (mode === 'image') document.getElementById('uploadTitle').textContent = 'Upload Image';
            if (mode === 'video') document.getElementById('uploadTitle').textContent = 'Upload Video';
            document.getElementById('fileName').textContent = 'Drag & drop or click to browse';
            document.getElementById('analyzeBtn').disabled = true;
            document.getElementById('imageResults').classList.add('hidden');
            document.getElementById('videoResults').classList.add('hidden');
            document.getElementById('alertBanner').classList.add('hidden');
        }

        function triggerUpload() {
            if (currentMode === 'webcam') return;
            document.getElementById(currentMode === 'image' ? 'imageInput' : 'videoInput').click();
        }

        document.getElementById('imageInput').addEventListener('change', function() {
            if (this.files[0]) {
                document.getElementById('fileName').textContent = this.files[0].name;
                document.getElementById('analyzeBtn').disabled = false;
            }
        });

        document.getElementById('videoInput').addEventListener('change', function() {
            if (this.files[0]) {
                document.getElementById('fileName').textContent = this.files[0].name;
                document.getElementById('analyzeBtn').disabled = false;
            }
        });

        const uploadArea = document.getElementById('uploadArea');
        uploadArea.addEventListener('dragover', (e) => { e.preventDefault(); uploadArea.classList.add('border-indigo-500', 'bg-slate-700/30'); });
        uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('border-indigo-500', 'bg-slate-700/30'));
        uploadArea.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadArea.classList.remove('border-indigo-500', 'bg-slate-700/30');
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                const input = document.getElementById(currentMode === 'image' ? 'imageInput' : 'videoInput');
                input.files = files;
                document.getElementById('fileName').textContent = files[0].name;
                document.getElementById('analyzeBtn').disabled = false;
            }
        });

        async function startWebcam() {
            try {
                webcamStream = await navigator.mediaDevices.getUserMedia({ video: { width: 640, height: 480 }, audio: false });
                const video = document.getElementById('webcamVideo');
                video.srcObject = webcamStream;
                await new Promise(r => video.onloadedmetadata = r);
                await video.play();
                document.getElementById('startWebcamBtn').disabled = true;
                document.getElementById('stopWebcamBtn').disabled = false;
                document.getElementById('webcamDot').className = 'w-2 h-2 rounded-full bg-emerald-400 animate-pulse';
                document.getElementById('webcamStatusText').textContent = 'Live';
                webcamBusy = false;
                const interval = parseInt(document.getElementById('webcamFps').value);
                webcamInterval = setInterval(captureAndAnalyze, interval);
            } catch(e) {
                alert('Camera error: ' + e.message);
            }
        }

        function stopWebcam() {
            if (webcamInterval) { clearInterval(webcamInterval); webcamInterval = null; }
            if (webcamStream) { webcamStream.getTracks().forEach(t => t.stop()); webcamStream = null; }
            webcamBusy = false;
            const video = document.getElementById('webcamVideo');
            if (video) video.srcObject = null;
            const startBtn = document.getElementById('startWebcamBtn');
            const stopBtn = document.getElementById('stopWebcamBtn');
            const dot = document.getElementById('webcamDot');
            const statusText = document.getElementById('webcamStatusText');
            if (startBtn) startBtn.disabled = false;
            if (stopBtn) stopBtn.disabled = true;
            if (dot) dot.className = 'w-2 h-2 rounded-full bg-slate-500';
            if (statusText) statusText.textContent = 'Idle';
        }

        async function captureAndAnalyze() {
            if (webcamBusy) return;  // skip if previous request still running
            const video = document.getElementById('webcamVideo');
            if (!video || !video.videoWidth || !webcamStream) return;
            webcamBusy = true;
            try {
                webcamCanvas.width = video.videoWidth;
                webcamCanvas.height = video.videoHeight;
                webcamCanvas.getContext('2d').drawImage(video, 0, 0);
                const blob = await new Promise(r => webcamCanvas.toBlob(r, 'image/jpeg', 0.85));
                if (!blob) return;
                const formData = new FormData();
                formData.append('file', blob, 'frame.jpg');
                const threshold = document.getElementById('thresholdSlider').value;
                const res = await fetch(`/webcam-frame?threshold=${threshold}`, { method: 'POST', body: formData });
                if (!res.ok) return;
                const data = await res.json();
                // Update detection image
                const outImg = document.getElementById('webcamOutput');
                outImg.src = data.output_image;
                outImg.style.display = 'block';
                // Update stats
                document.getElementById('wcPersonCount').textContent = data.person_count;
                document.getElementById('wcMale').textContent = data.male_count;
                document.getElementById('wcFemale').textContent = data.female_count;
                document.getElementById('wcConfidence').textContent = data.avg_confidence + '%';
                document.getElementById('wcSpeed').textContent = data.processing_time_ms + 'ms';
                const wcDensity = document.getElementById('wcDensity');
                wcDensity.textContent = data.density_level;
                wcDensity.className = 'text-sm font-bold px-2 py-1 rounded-full ' + (densityColors[data.density_level] || 'bg-slate-600 text-slate-200');
                const objHtml = Object.entries(data.object_counts || {}).map(([k,v]) =>
                    `<span class="bg-slate-700 text-white text-xs px-2 py-1 rounded-lg">${k}: ${v}</span>`).join('');
                document.getElementById('wcObjects').innerHTML = objHtml;
                if (data.alert) {
                    document.getElementById('alertBanner').classList.remove('hidden');
                    document.getElementById('alertMsg').textContent = `🚨 ${data.person_count} people in live feed — threshold exceeded!`;
                } else {
                    document.getElementById('alertBanner').classList.add('hidden');
                }
            } catch(e) {
                console.error('Webcam analysis error:', e);
            } finally {
                webcamBusy = false;
            }
        }

        async function analyze() {
            currentMode === 'image' ? await analyzeImage() : await analyzeVideo();
        }

        async function analyzeImage() {
            const file = document.getElementById('imageInput').files[0];
            if (!file) return;

            const threshold = document.getElementById('thresholdSlider').value;
            document.getElementById('analyzeBtn').disabled = true;
            document.getElementById('loading').classList.remove('hidden');
            document.getElementById('loadingText').textContent = 'Analyzing image...';
            document.getElementById('imageResults').classList.add('hidden');
            document.getElementById('alertBanner').classList.add('hidden');

            const reader = new FileReader();
            reader.onload = (e) => document.getElementById('originalImage').src = e.target.result;
            reader.readAsDataURL(file);

            const formData = new FormData();
            formData.append('file', file);

            try {
                const response = await fetch(`/upload?threshold=${threshold}`, { method: 'POST', body: formData });
                const result = await response.json();

                document.getElementById('loading').classList.add('hidden');

                if (!response.ok) throw new Error(result.error || 'Failed');

                document.getElementById('imageResults').classList.remove('hidden');
                document.getElementById('personCount').textContent = result.person_count;
                document.getElementById('maleCount').textContent = result.male_count;
                document.getElementById('femaleCount').textContent = result.female_count;
                document.getElementById('carCount').textContent = (result.object_counts && result.object_counts['Car']) || 0;
                document.getElementById('avgConfidence').textContent = result.avg_confidence + '%';
                document.getElementById('processingTime').textContent = result.processing_time_ms + 'ms';

                const badge = document.getElementById('densityBadge');
                badge.textContent = result.density_level;
                badge.className = 'text-sm font-bold px-3 py-1 rounded-full ' + (densityColors[result.density_level] || '');

                document.getElementById('outputImage').src = result.output_image;
                document.getElementById('heatmapImage').src = result.heatmap_image;
                showImgTab('original');

                if (result.alert) {
                    document.getElementById('alertBanner').classList.remove('hidden');
                    document.getElementById('alertMsg').textContent = `${result.person_count} people detected — exceeds threshold of ${result.alert_threshold}`;
                }

            } catch (err) {
                document.getElementById('loading').classList.add('hidden');
                alert('Error: ' + err.message);
            } finally {
                document.getElementById('analyzeBtn').disabled = false;
            }
        }

        async function analyzeVideo() {
            const file = document.getElementById('videoInput').files[0];
            if (!file) return;

            document.getElementById('analyzeBtn').disabled = true;
            document.getElementById('loading').classList.remove('hidden');
            document.getElementById('loadingText').textContent = 'Processing video... this may take a moment';
            document.getElementById('videoResults').classList.add('hidden');
            document.getElementById('alertBanner').classList.add('hidden');

            const formData = new FormData();
            formData.append('file', file);

            try {
                const response = await fetch('/upload-video', { method: 'POST', body: formData });
                const result = await response.json();

                document.getElementById('loading').classList.add('hidden');
                if (!response.ok) throw new Error(result.error || 'Failed');

                document.getElementById('videoResults').classList.remove('hidden');
                document.getElementById('maxCount').textContent = result.max_count;
                document.getElementById('maxPersons').textContent = result.max_persons;
                document.getElementById('maxCars').textContent = result.max_cars;
                document.getElementById('avgCount').textContent = result.avg_count;

                const badge = document.getElementById('videoDensityBadge');
                badge.textContent = result.density_level;
                badge.className = 'text-sm font-bold px-3 py-1 rounded-full ' + (densityColors[result.density_level] || '');

                document.getElementById('videoPreview').src = result.preview_image;
                document.getElementById('videoHeatmap').src = result.heatmap_image;
                showVidTab('preview');

                if (result.alert) {
                    document.getElementById('alertBanner').classList.remove('hidden');
                    document.getElementById('alertMsg').textContent = `Peak of ${result.max_count} people detected — exceeds threshold of ${result.alert_threshold}`;
                }

                renderChart(result.frame_results);

            } catch (err) {
                document.getElementById('loading').classList.add('hidden');
                alert('Error: ' + err.message);
            } finally {
                document.getElementById('analyzeBtn').disabled = false;
            }
        }

        function renderChart(frameResults) {
            if (crowdChartInstance) crowdChartInstance.destroy();
            const ctx = document.getElementById('crowdChart').getContext('2d');
            crowdChartInstance = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: frameResults.map(r => r.second + 's'),
                    datasets: [{
                        label: 'People Count',
                        data: frameResults.map(r => r.count),
                        borderColor: '#6366f1',
                        backgroundColor: 'rgba(99,102,241,0.15)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 5,
                        pointHoverRadius: 8,
                        pointBackgroundColor: '#6366f1',
                        pointHoverBackgroundColor: '#a855f7',
                        pointHoverBorderColor: '#fff',
                        pointHoverBorderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    cursor: 'pointer',
                    plugins: {
                        legend: { labels: { color: '#94a3b8' } },
                        tooltip: {
                            callbacks: {
                                afterLabel: () => '👆 Click to view detection'
                            }
                        }
                    },
                    scales: {
                        x: { ticks: { color: '#94a3b8' }, grid: { color: '#1e293b' } },
                        y: { ticks: { color: '#94a3b8' }, grid: { color: '#1e293b' }, beginAtZero: true }
                    },
                    onClick: (event, elements) => {
                        if (elements.length > 0) {
                            const idx = elements[0].index;
                            openFrameModal(frameResults[idx]);
                        }
                    }
                }
            });
        }

        function openFrameModal(frame) {
            document.getElementById('modalTitle').textContent = `⏱ ${frame.second}s — ${frame.count} people detected`;
            document.getElementById('modalImage').src = frame.frame_image;
            const objects = Object.entries(frame.objects || {}).map(([k,v]) => `<div class="bg-slate-900/60 rounded-xl p-3 text-center"><p class="text-slate-400 text-xs">${k}</p><p class="text-white font-bold text-xl">${v}</p></div>`).join('');
            document.getElementById('modalStats').innerHTML = `
                <div class="bg-slate-900/60 rounded-xl p-3 text-center">
                    <p class="text-slate-400 text-xs">👤 People</p>
                    <p class="text-indigo-400 font-bold text-xl">${frame.count}</p>
                    <div class="flex justify-center gap-2 mt-1">
                        <span class="text-xs text-blue-400">👨 ${frame.males}</span>
                        <span class="text-xs text-pink-400">👩 ${frame.females}</span>
                    </div>
                </div>
                <div class="bg-slate-900/60 rounded-xl p-3 text-center">
                    <p class="text-slate-400 text-xs">🎯 Confidence</p>
                    <p class="text-emerald-400 font-bold text-xl">${frame.confidence}%</p>
                </div>
                <div class="bg-slate-900/60 rounded-xl p-3 text-center">
                    <p class="text-slate-400 text-xs">⚡ Process Time</p>
                    <p class="text-sky-400 font-bold text-xl">${frame.processing_time_ms}ms</p>
                </div>
                ${objects}
            `;
            document.getElementById('frameModal').classList.remove('hidden');
            document.getElementById('frameModal').classList.add('flex');
        }

        function closeModal() {
            document.getElementById('frameModal').classList.add('hidden');
            document.getElementById('frameModal').classList.remove('flex');
        }

        document.getElementById('frameModal').addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });

        function showImgTab(tab) {
            ['original', 'detection', 'heatmap'].forEach(t => {
                const imgId = t === 'original' ? 'originalImage' : t === 'detection' ? 'outputImage' : 'heatmapImage';
                const btnId = t === 'original' ? 'btnOriginal' : t === 'detection' ? 'btnDetection' : 'btnHeatmap';
                document.getElementById(imgId).classList.toggle('hidden', t !== tab);
                document.getElementById(btnId).className = t === tab
                    ? 'tab-active px-4 py-1.5 rounded-lg text-sm font-semibold transition-all'
                    : 'px-4 py-1.5 rounded-lg text-sm font-semibold text-slate-400 hover:text-white transition-all';
            });
        }

        function showVidTab(tab) {
            document.getElementById('videoPreview').classList.toggle('hidden', tab !== 'preview');
            document.getElementById('videoHeatmap').classList.toggle('hidden', tab !== 'vidheatmap');
            document.getElementById('btnVidPreview').className = tab === 'preview'
                ? 'tab-active px-4 py-1.5 rounded-lg text-sm font-semibold transition-all'
                : 'px-4 py-1.5 rounded-lg text-sm font-semibold text-slate-400 hover:text-white transition-all';
            document.getElementById('btnVidHeatmap').className = tab === 'vidheatmap'
                ? 'tab-active px-4 py-1.5 rounded-lg text-sm font-semibold transition-all'
                : 'px-4 py-1.5 rounded-lg text-sm font-semibold text-slate-400 hover:text-white transition-all';
        }

        async function toggleHistory() {
            historyVisible = !historyVisible;
            const panel = document.getElementById('historyPanel');
            panel.classList.toggle('hidden', !historyVisible);
            if (historyVisible) {
                await loadStats();
                await loadHistory();
            }
        }

        async function loadStats() {
            try {
                const res = await fetch('/stats');
                const s = await res.json();
                document.getElementById('statsCards').innerHTML = [
                    ['Total Analyses', s.total_analyses, 'text-indigo-400'],
                    ['People Detected', s.total_people_detected, 'text-purple-400'],
                    ['Total Alerts', s.total_alerts, 'text-red-400'],
                    ['Avg Confidence', Math.round(s.overall_avg_confidence) + '%', 'text-emerald-400'],
                ].map(([label, val, cls]) => `
                    <div class="bg-slate-900/40 rounded-2xl p-4 text-center">
                        <p class="text-slate-400 text-xs mb-1">${label}</p>
                        <p class="text-2xl font-bold ${cls}">${val}</p>
                    </div>`).join('');
            } catch(e) { console.error(e); }
        }

        async function loadHistory() {
            try {
                const res = await fetch('/history?limit=20');
                const rows = await res.json();
                const tbody = document.getElementById('historyTableBody');
                if (!rows.length) {
                    tbody.innerHTML = '<tr><td colspan="8" class="text-center text-slate-500 py-6">No history yet</td></tr>';
                    return;
                }
                tbody.innerHTML = rows.map(r => `
                    <tr class="hover:bg-slate-700/30 transition-colors">
                        <td class="px-4 py-3">
                            <span class="text-xs px-2 py-1 rounded-full ${
                                r.type === 'image' ? 'bg-indigo-500/20 text-indigo-400' :
                                r.type === 'video' ? 'bg-purple-500/20 text-purple-400' :
                                'bg-sky-500/20 text-sky-400'
                            }">${r.type}</span>
                        </td>
                        <td class="px-4 py-3 text-slate-300 max-w-[120px] truncate" title="${r.filename}">${r.filename}</td>
                        <td class="px-4 py-3 text-white font-bold">${r.person_count}</td>
                        <td class="px-4 py-3 text-orange-400">${r.car_count}</td>
                        <td class="px-4 py-3">
                            <span class="text-xs font-semibold px-2 py-1 rounded-full ${
                                densityColors[r.density_level] || 'bg-slate-600 text-slate-200'
                            }">${r.density_level}</span>
                        </td>
                        <td class="px-4 py-3 text-emerald-400">${r.avg_confidence}%</td>
                        <td class="px-4 py-3">${r.alert ? '<span class="text-red-400 font-bold">🚨 Yes</span>' : '<span class="text-slate-500">No</span>'}</td>
                        <td class="px-4 py-3 text-slate-400 text-xs">${r.created_at}</td>
                    </tr>`).join('');
            } catch(e) { console.error(e); }
        }

        async function clearHistory() {
            if (!confirm('Clear all history? This cannot be undone.')) return;
            await fetch('/history', { method: 'DELETE' });
            await loadHistory();
            await loadStats();
        }

        function downloadResult() {
            const img = document.getElementById('outputImage');
            const a = document.createElement('a');
            a.href = img.src;
            a.download = 'crowd-detection-result.jpg';
            a.click();
        }
    </script>
</body>
</html>
